{r}

?difftime

?wday
?group_by
orders_analysis <- orders %>%
  mutate(
    delivery_duration = as.numeric(difftime(order_delivered_customer_date, 
                                           order_purchase_timestamp, 
                                           units = "days")),
    purchase_day = wday(order_purchase_timestamp, label = TRUE, abbr = FALSE)
  ) %>%
  filter(!is.na(delivery_duration)) 

daily_performance <- orders_analysis %>%
  group_by(purchase_day) %>%
  summarise(avg_delivery_time = mean(delivery_duration, na.rm = TRUE))

{r}
ggplot(daily_performance, aes(x = purchase_day, y = avg_delivery_time, fill = purchase_day)) +
  geom_col() +
  theme_minimal() +
  labs(title = "Average Delivery Time by Day of Purchase",
       subtitle = "Does ordering on a weekend affect delivery speed?",
       x = "Day of Purchase",
       y = "Average Delivery Days") +
  theme(legend.position = "none")

